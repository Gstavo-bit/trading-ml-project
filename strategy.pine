//@version=5
strategy("Low Drawdown Strategy (MACD + EMA200 + ATR Filter)", 
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=5)

// INPUTS
fastLen   = input.int(12, "MACD Fast")
slowLen   = input.int(26, "MACD Slow")
signalLen = input.int(9, "MACD Signal")

emaFastLen = input.int(50, "EMA 50")
emaSlowLen = input.int(200, "EMA 200")

atrLen  = input.int(14, "ATR Length")
riskATR = input.float(1.0, "Stop ATR (mais curto)")
rr      = input.float(1.8, "Risk/Reward")

// INDICATORS
[macd, signal, hist] = ta.macd(close, fastLen, slowLen, signalLen)
ema50  = ta.ema(close, emaFastLen)
ema200 = ta.ema(close, emaSlowLen)
atr = ta.atr(atrLen)

// TREND FILTER (FORTE)
bullTrend = close > ema200 and ema50 > ema200
bearTrend = close < ema200 and ema50 < ema200

// VOLATILITY FILTER (evita chop)
volatility = atr > ta.sma(atr, 20)

// ENTRY
longSignal  = ta.crossover(macd, signal) and bullTrend and volatility
shortSignal = ta.crossunder(macd, signal) and bearTrend and volatility

// RISK MANAGEMENT (mais conservador)
longSL  = close - atr * riskATR
longTP  = close + atr * riskATR * rr

shortSL = close + atr * riskATR
shortTP = close - atr * riskATR * rr

// EXECUTION
if (longSignal)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", from_entry="Long", stop=longSL, limit=longTP)

if (shortSignal)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", from_entry="Short", stop=shortSL, limit=shortTP)

// PLOT
plot(ema50, color=color.orange, title="EMA 50")
plot(ema200, color=color.blue, title="EMA 200")

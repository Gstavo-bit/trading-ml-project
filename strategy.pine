//@version=5
strategy("Quant Trading Strategy (MACD + EMA + ATR)", 
     overlay=true, 
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10)

// ======================
// INPUTS
// ======================
fastLen   = input.int(12, "MACD Fast Length")
slowLen   = input.int(26, "MACD Slow Length")
signalLen = input.int(9, "MACD Signal Length")

emaLen    = input.int(50, "Trend EMA Length")

atrLen    = input.int(14, "ATR Length")
riskMult  = input.float(1.5, "Stop Loss (ATR Multiplier)")
rewardMult= input.float(2.0, "Take Profit (RR Multiplier)")

// ======================
// INDICATORS
// ======================
[macd, signal, hist] = ta.macd(close, fastLen, slowLen, signalLen)
emaTrend = ta.ema(close, emaLen)
atr = ta.atr(atrLen)

// ======================
// TREND FILTER
// ======================
bullTrend = close > emaTrend
bearTrend = close < emaTrend

// ======================
// SIGNALS
// ======================
longSignal  = ta.crossover(macd, signal) and bullTrend
shortSignal = ta.crossunder(macd, signal) and bearTrend

// ======================
// RISK MANAGEMENT
// ======================
longSL  = close - atr * riskMult
longTP  = close + atr * riskMult * rewardMult

shortSL = close + atr * riskMult
shortTP = close - atr * riskMult * rewardMult

// ======================
// EXECUTION
// ======================
if (longSignal)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", 
        from_entry="Long", 
        stop=longSL, 
        limit=longTP)

if (shortSignal)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", 
        from_entry="Short", 
        stop=shortSL, 
        limit=shortTP)

// ======================
// PLOTS
// ======================
plot(emaTrend, color=color.orange, linewidth=2, title="EMA Trend")

plot(hist, 
     style=plot.style_columns, 
     color=hist >= 0 ? color.green : color.red, 
     title="MACD Histogram")

plot(macd, color=color.blue, title="MACD")
plot(signal, color=color.orange, title="Signal")

// ======================
// VISUAL SIGNALS
// ======================
plotshape(longSignal, 
     title="Buy Signal", 
     location=location.belowbar, 
     color=color.green, 
     style=shape.triangleup, 
     size=size.small)

plotshape(shortSignal, 
     title="Sell Signal", 
     location=location.abovebar, 
     color=color.red, 
     style=shape.triangledown, 
     size=size.small)
